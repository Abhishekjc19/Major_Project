{
  "name": "omnibus-backend",
  "version": "1.0.0",
  "description": "OmniBus - Real-time bus tracking backend",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "tsx seed.ts",
    "typeorm": "typeorm",
    "migrate": "typeorm migration:run -d dist/config/database.js",
    "migrate:create": "typeorm migration:create",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.9.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "helmet": "^7.1.0",
    "jwt-simple": "^0.5.6",
    "pg": "^8.11.3",
    "socket.io": "^4.8.3",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.19",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/uuid": "^9.0.7",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
